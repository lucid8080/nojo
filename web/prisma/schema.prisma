// Phase 6: run persistence. Phase 7: User for auth and run ownership.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SkillCardStatus {
  DRAFT
  PUBLISHED
}

enum SkillCardSourceType {
  MANUAL
  IMPORTED_MARKDOWN
  IMPORTED_SKILL
  OTHER
}

enum FileCreatorType {
  USER
  AGENT
}

/// Durable user-owned container for arbitrary files and versioned revisions.
model Project {
  id String @id @default(cuid())

  ownerUserId String
  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  name String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files ProjectFile[]
  workspaceConversations WorkspaceConversation[]

  @@index([ownerUserId])
  @@index([createdAt])
}

/// Stable file identity inside a project (keeps metadata + pointer to current revision).
model ProjectFile {
  id String @id @default(cuid())

  projectId String
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  ownerUserId String

  filename String
  mimeType String
  extension String?
  sizeBytes Int

  currentRevisionId String? @unique
  currentRevision FileRevision? @relation("CurrentProjectFileRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull)

  revisions FileRevision[] @relation("ProjectFileRevisions")

  createdByType FileCreatorType @default(USER)
  createdByUserId String?
  createdByAgentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  @@index([projectId])
  @@index([ownerUserId])
  @@index([updatedAt])
}

/// Append-only revision history for a `ProjectFile`.
model FileRevision {
  id String @id @default(cuid())

  projectFileId String
  projectFile ProjectFile @relation("ProjectFileRevisions", fields: [projectFileId], references: [id], onDelete: Cascade)

  currentOfProjectFile ProjectFile? @relation("CurrentProjectFileRevision")

  versionNumber Int
  storageKey String

  mimeType String
  sizeBytes Int
  changeSummary String?

  createdByType FileCreatorType @default(USER)
  createdByUserId String?
  createdByAgentId String?

  createdAt DateTime @default(now())

  @@unique([projectFileId, versionNumber])
  @@index([projectFileId])
  @@index([createdAt])
}

/// CMS skill definition card (full markdown body); public when PUBLISHED.
model SkillCard {
  id                     String              @id @default(cuid())
  slug                   String              @unique
  title                  String
  summary                String
  category               String
  /// JSON array of tag strings
  tags                   Json                @default("[]")
  status                 SkillCardStatus     @default(DRAFT)
  fullDefinitionMarkdown String
  sourceType             SkillCardSourceType?
  sourcePath             String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@index([status])
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  name                   String?
  /// IANA timezone for scheduling (e.g. America/Toronto). Used when parsing local times in reminders.
  timeZone               String?
  role                   UserRole                @default(USER)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  runs                   Run[]
  workspaceConversations WorkspaceConversation[]
  workspaceAgents        UserWorkspaceAgent[]
  projects               Project[]

  @@index([createdAt])
}

/// User-created Agent Workspace roster row (stable `agentId` e.g. nojo-team-{uuid}).
model UserWorkspaceAgent {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId         String
  name            String
  initials        String
  role            String
  avatarClass     String
  categoryLabel   String?
  /// Optional JSON: NojoAgentIdentityOverride fields (description, skills, avatar file, etc.)
  identityJson    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, agentId])
  @@index([userId])
  @@index([createdAt])
}

/// User-scoped Agent Workspace room; `id` is the client/OpenClaw `conversationId`.
model WorkspaceConversation {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  /// JSON array of agent ids (built-in nojo-* and/or user nojo-team-*)
  agentIds       Json
  primaryAgentId String
  /// Optional durable-files organization link.
  ///
  /// Note: DB relation cannot enforce that Project.ownerUserId matches WorkspaceConversation.userId,
  /// so we must validate ownership server-side.
  projectId      String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model Run {
  id             String   @id @default(cuid())
  openclawRunId  String?
  prompt         String
  agentId        String?
  conversationId String?
  status         String   @default("submitted")
  errorMessage   String?
  lastCheckedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([status])
}
