## Database (SQLite for local MVP)
# Example: file:./dev.db
DATABASE_URL="file:./dev.db"

## OpenClaw (server-only)
#
# Project-local runtime data (agent scaffolds, device identity, cron JSON mirror) defaults to
# `web/.openclaw/` (i.e. `process.cwd()/.openclaw` when you run the app from `web/`).
# Override the root directory if you want data elsewhere (portable checkout, CI, etc.):
# NOJO_OPENCLAW_RUNTIME_ROOT="D:/path/to/nojo2/web/.openclaw"
# (alias: OPENCLAW_RUNTIME_ROOT)
#
# Per-path overrides still win: OPENCLAW_AGENTS_ROOT, OPENCLAW_CRON_JOBS_PATH,
# OPENCLAW_DEVICE_IDENTITY_PATH, OPENCLAW_DEVICE_TOKEN_PATH.
#
# Optional: copy bundled repo skills (`skills/<slug>/` next to the monorepo `web/` folder) into
# **canonical** Nojo agents’ OpenClaw workspaces (comma-separated catalog ids, e.g. sk-9).
# User workspace agents use Team-assigned skills instead; leave unset unless you need this.
# NOJO_CANONICAL_AGENT_BUNDLED_SKILL_IDS=sk-9
#
# Base URL of your OpenClaw instance (Proxmox / LAN host).
# Example: http://192.168.1.50:8080
OPENCLAW_BASE_URL="http://192.168.0.56:7070"

# Optional: WebSocket URL for the gateway control plane if it is not the same host/port as OPENCLAW_BASE_URL.
# Default gateway port is often 18789 — set explicitly when HTTP API and WS differ.
# Full URL: ws://192.168.0.56:18789 — or host:port only (ws:// is added): 192.168.0.56:18789
# If you see ECONNREFUSED, the gateway is not listening on that IP:port (wrong port, service down, or bind is 127.0.0.1 only while Next.js runs on another PC).
# OPENCLAW_GATEWAY_WS_URL=

# Gateway auth: used for health and other gateway endpoints (e.g. GET /health).
OPENCLAW_GATEWAY_TOKEN="timeless"

# Hooks auth: required for POST /hooks/agent. Do not assume same as gateway.
OPENCLAW_HOOKS_TOKEN="timeless"

# Optional request timeout in milliseconds (default: 8000).
OPENCLAW_TIMEOUT_MS=8000

# WebSocket `connect` scopes for server-side cron mutations only (`cron.add` from chat reminders).
# Default: operator.read,operator.write,operator.admin (cron.add requires admin on the gateway).
# Comma-separated. Chat uses read+write only — this env applies only to the short-lived cron client.
# If the gateway returns "missing scope: operator.admin", ensure this includes operator.admin and
# that the Nojo device is approved for those scopes: `openclaw devices list` / `approve` on the gateway host.
# NOJO_OPENCLAW_CRON_GATEWAY_SCOPES=operator.read,operator.write,operator.admin

# Schedules UI loads cron jobs from the OpenClaw gateway (canonical). When the gateway is
# unreachable, the API can fall back to local JSON (see OPENCLAW_CRON_JOBS_PATH / runtime mirror).
# Set to false to show an error instead of using the disk mirror (default: true).
# NOJO_CRON_ALLOW_DISK_FALLBACK=

# Client-only: show technical schedule source + API warnings on the Schedules page (default: off).
# Alternatively open /schedules?schedulesDebug=1 or ?debug=schedules
# NEXT_PUBLIC_NOJO_SCHEDULES_DEBUG=true

## Auth (Phase 7 — minimal credentials MVP)
# Secret for NextAuth JWT/session signing. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# URL of this app (e.g. http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000
# Demo user for credentials login (MVP only)
AUTH_DEMO_EMAIL=demo@example.com
AUTH_DEMO_PASSWORD=demo

# Promote matching user(s) to ADMIN on successful login (comma-separated optional).
# NOJO_ADMIN_EMAIL=demo@example.com
# NOJO_ADMIN_EMAILS=ops@example.com,other@example.com

# Default IANA timezone for parsing reminder phrases when the user has not set User.timeZone (API PATCH /api/user/settings).
# NOJO_REMINDER_DEFAULT_TIMEZONE=America/Toronto

