# Ignore editor/agent scratch files
.cursor/

# Ignore app build/deps folders (mostly inside web/)
web/node_modules/
web/.next/
web/out/
web/build/

# Ignore nested git directory (if any)
web/.git/

# Ignore renamed nested git directory backups (if detached/renamed)
web/.git.bak_*/

# Ignore environment files anywhere under web/
web/.env*

# Ignore local database artifacts (common with Prisma SQLite)
web/prisma/*.db

# Persisted server-side OpenClaw device identity (contains private key seed)
web/.openclaw/

